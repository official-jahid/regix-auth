// ============================================================
// REGIX AUTH SYSTEM - PRISMA SCHEMA
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// USER MODEL
// ============================================================
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String
  displayName   String?
  avatarUrl     String?
  role          String   @default("USER") // USER, ADMIN, MOD
  isActive      Boolean  @default(true)
  isBlacklisted Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sessions         Session[]
  devices          Device[]
  discordAccount   DiscordAccount?
  premiumKeys      PremiumKey[]
  loginHistory     LoginHistory[]
  blacklistHistory BlacklistEntry[]
  otps             OtpCode[]
}

// ============================================================
// SESSION MODEL
// ============================================================
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============================================================
// DEVICE MODEL (HWID, SID tracking)
// ============================================================
model Device {
  id           String    @id @default(cuid())
  userId       String
  hwid         String // Hardware ID
  sid          String? // Security Identifier
  ip           String?
  isActive     Boolean   @default(true)
  lastSeenAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sidUpdatedAt DateTime? // Track when SID was last changed (24h cooldown)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hwid])
  @@index([hwid])
  @@index([userId])
}

// ============================================================
// DISCORD ACCOUNT (OAuth linking)
// ============================================================
model DiscordAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  discordId     String   @unique
  username      String?
  discriminator String?
  avatarUrl     String?
  accessToken   String?
  refreshToken  String?
  linkedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([discordId])
}

// ============================================================
// PREMIUM KEY MODEL
// ============================================================
model PremiumKey {
  id         String    @id @default(cuid())
  key        String    @unique
  duration   Int // Duration in days (0 = lifetime)
  isLifetime Boolean   @default(false)
  isRedeemed Boolean   @default(false)
  redeemedAt DateTime?
  expiresAt  DateTime? // null for lifetime
  userId     String?
  isActive   Boolean   @default(true)
  isIpLocked Boolean   @default(false)
  lockedIp   String?
  createdBy  String // Admin user ID who created this key
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([key])
  @@index([userId])
}

// ============================================================
// LOGIN HISTORY
// ============================================================
model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  ip         String?
  method     String // "email", "discord", "hwid", "api"
  userAgent  String?
  success    Boolean
  failReason String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// BLACKLIST / BAN HISTORY
// ============================================================
model BlacklistEntry {
  id            String   @id @default(cuid())
  userId        String
  reason        String?
  blacklistedBy String // Admin user ID
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// AUDIT LOG
// ============================================================
model AuditLog {
  id        String   @id @default(cuid())
  action    String // e.g. "USER_CREATED", "KEY_GENERATED", "USER_BLACKLISTED"
  userId    String?
  details   String? // JSON string with details
  ip        String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

// ============================================================
// OTP CODE MODEL (Email verification, password reset)
// ============================================================
model OtpCode {
  id        String    @id @default(cuid())
  userId    String
  email     String
  code      String
  type      String // "EMAIL_VERIFICATION", "PASSWORD_RESET"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([email, code, type])
  @@index([createdAt])
}
