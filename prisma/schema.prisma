// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String          @id
  name           String
  email          String
  emailVerified  Boolean         @default(false)
  image          String?
  role           String          @default("user")
  isActive       Boolean         @default(true)
  isBlacklisted  Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessions       Session[]
  accounts       Account[]
  devices        Device[]
  premiumKeys    PremiumKey[]
  discordAccount DiscordAccount?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Device {
  id        String   @id
  hwid      String?
  sid       String?
  ipAddress String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("device")
}

model PremiumKey {
  id         String    @id
  key        String    @unique
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  duration   Int       @default(0)
  isLifetime Boolean   @default(false)
  isActive   Boolean   @default(true)
  status     String    @default("active") // active, expired, blocked, used
  ipLock     String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  redeemedAt DateTime?

  @@index([userId])
  @@map("premium_key")
}

model DiscordAccount {
  id            String   @id
  discordId     String   @unique
  username      String?
  discriminator String?
  avatarUrl     String?
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([discordId])
  @@map("discord_account")
}

model OtpCode {
  id            String   @id
  discordUserId String   @unique
  otp           String
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([discordUserId])
  @@map("otp_code")
}

model BotWhitelist {
  id        String   @id
  discordId String   @unique
  addedBy   String
  reason    String?
  createdAt DateTime @default(now())

  @@index([discordId])
  @@map("bot_whitelist")
}

model GuildSettings {
  id                    String   @id
  guildId               String   @unique
  verificationEnabled   Boolean  @default(false)
  verifiedRoleId        String?
  verificationChannelId String?
  antiNukeEnabled       Boolean  @default(false)
  antiRaidEnabled       Boolean  @default(false)
  antiSpamEnabled       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([guildId])
  @@map("guild_settings")
}

model AntiNukeConfig {
  id                 String   @id
  guildId            String   @unique
  banLimit           Int      @default(5)
  kickLimit          Int      @default(5)
  channelDeleteLimit Int      @default(3)
  channelCreateLimit Int      @default(3)
  roleCreateLimit    Int      @default(3)
  roleDeleteLimit    Int      @default(3)
  webhookLimit       Int      @default(3)
  punishment         String   @default("ban") // ban, kick, role-remove
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([guildId])
  @@map("anti_nuke_config")
}

model AntiRaidConfig {
  id                String   @id
  guildId           String   @unique
  joinThreshold     Int      @default(10)
  joinTimeWindow    Int      @default(10) // seconds
  messageThreshold  Int      @default(20)
  messageTimeWindow Int      @default(10) // seconds
  mentionThreshold  Int      @default(10)
  punishment        String   @default("ban")
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([guildId])
  @@map("anti_raid_config")
}

model AntiSpamConfig {
  id             String   @id
  guildId        String   @unique
  messageLimit   Int      @default(5)
  timeWindow     Int      @default(5) // seconds
  duplicateLimit Int      @default(3)
  punishment     String   @default("mute")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([guildId])
  @@map("anti_spam_config")
}

model AuditLog {
  id        String   @id
  userId    String?
  guildId   String?
  action    String
  target    String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([guildId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

model AdminIpAllowlist {
  id        String   @id
  ipAddress String   @unique
  label     String?
  addedBy   String
  createdAt DateTime @default(now())

  @@map("admin_ip_allowlist")
}

model TotpSecret {
  id        String   @id
  userId    String   @unique
  secret    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("totp_secret")
}

model TotpBackupCode {
  id     String  @id
  userId String
  code   String
  used   Boolean @default(false)

  @@index([userId])
  @@map("totp_backup_code")
}
