{
  "name": "regix-auth",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,bot -c cyan,magenta \"bun run dev:web\" \"bun run dev:bot\"",
    "dev:web": "prisma generate && next dev",
    "dev:bot": "bun run src/bot/start.ts",
    "bot": "bun run src/bot/start.ts",
    "build": "prisma generate && next build",
    "start": "concurrently -n web,bot -c cyan,magenta \"next start\" \"bun run src/bot/start.ts\"",
    "lint": "eslint",
    "prod": "prisma generate && eslint && next build && concurrently -n web,bot \"next start\" \"bun run src/bot/start.ts\"",
    "migrate": "prisma migrate dev && prisma generate",
    "studio": "prisma studio --browser none"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@shadcn/react": "^0.2.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^10.0.3",
    "date-fns": "^4.4.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^4.12.1",
    "react-toastify": "^11.1.0",
    "recharts": "3.8.0",
    "resend": "^6.17.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@prisma/engines",
    "msw",
    "prisma",
    "sharp",
    "unrs-resolver"
  ],
  "engines": {
    "node": ">=24.x.x",
    "npm": ">=11.x.x"
  },
  "author": "Jahid Ekbal Mallick",
  "license": "MIT",
  "homepage": "https://github.com/official-jahid/regix-auth#readme"
}
