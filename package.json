{
  "name": "basic-auth-profile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n next,bot -c cyan,green \"next dev\" \"bun run src/bot/start.ts\"",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "concurrently -n next,bot -c cyan,green \"next start -H 0.0.0.0 -p $PORT\" \"bun run src/bot/start.ts\"",
    "setup": "prisma migrate deploy && prisma generate && bun run prisma/seed-admin.ts",
    "migrate": "prisma migrate dev && prisma generate",
    "migrate:prod": "prisma migrate deploy && prisma generate",
    "lint": "npx eslint src --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write .",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@shadcn/react": "^0.2.1",
    "add": "^2.0.6",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^10.0.3",
    "date-fns": "^4.4.0",
    "discord.js": "^14.26.5",
    "dotenv": "^17.3.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^4.12.2",
    "react-toastify": "^11.0.5",
    "recharts": "3.8.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.5.0",
    "shadcn": "^4.1.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@prisma/engines",
    "msw",
    "prisma",
    "sharp",
    "unrs-resolver"
  ],
  "engines": {
    "node": ">=22.x.x",
    "npm": ">=11.x.x"
  },
  "author": "Jahid Ekbal Mallick",
  "license": "MIT",
  "homepage": "https://github.com/jahid-ekbal/basic-auth-profile"
}