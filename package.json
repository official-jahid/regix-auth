{
  "name": "regix-auth-system",
  "version": "3.0.0",
  "description": "REGIX Advanced Licensing & Auth Server with Discord Bot",
  "main": "server.js",
  "scripts": {
    "dev": "bun run server.js",
    "start": "node server.js",
    "build": "npm run build:css && npx prisma generate && npx prisma db push",
    "build:css": "tailwindcss -i ./public/css/app.css -o ./public/css/dist.css --minify",
    "dev:css": "tailwindcss -i ./public/css/app.css -o ./public/css/dist.css --watch",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "db:generate": "bunx prisma generate",
    "postinstall": "npx prisma generate"
  },
  "engines": {
    "node": ">=18.x",
    "bun": ">=1.x"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "discord.js": "^14.16.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2"
  }
}
