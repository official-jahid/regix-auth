# ============================================================
# REGIX AUTH SYSTEM - ENVIRONMENT VARIABLES
# ============================================================

# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# ==============================
# REQUIRED VARIABLES
# ==============================

# Prisma database URL (SQLite file path or Turso HTTP URL)
# SQLite: file:./prisma/dev.db
# Turso (production): https://your-db.turso.io
DATABASE_URL=

# Better Auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Better Auth base URL (your application's public URL)
# Dev: http://localhost:3000
# Prod: https://your-domain.com
BETTER_AUTH_URL=

# Admin lifetime access key for registration
ADMIN_LIFETIME_KEY=

# Server secret key (used for bot API auth and internal endpoints)
# Generate with: openssl rand -base64 32
SECRET_KEY=

# ==============================
# DISCORD BOT (optional)
# ==============================

# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Discord application client ID
DISCORD_CLIENT_ID=

# Discord guild/server ID where the bot operates
DISCORD_GUILD_ID=

# Discord role IDs for permissions
DISCORD_ADMIN_ROLE_ID=
DISCORD_MOD_ROLE_ID=

# Comma-separated list of super admin Discord user IDs
SUPER_ADMIN_IDS=

# Verified role ID for Discord verification system
DISCORD_VERIFIED_ROLE_ID=

# ==============================
# OPTIONAL
# ==============================

# Public app URL (override for CSRF origin validation)
# If not set, falls back to BETTER_AUTH_URL
NEXT_PUBLIC_APP_URL=