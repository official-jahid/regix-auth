# ============================================================
# REGIX AUTH SYSTEM - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values

# Database (SQLite by default)
DATABASE_URL=file:./prisma/dev.db
CHECKPOINT_DISABLE=1

# Server
PORT=3000
NODE_ENV=development

# Security (Generate strong random strings for production)
SECRET_KEY="your-secret-key-here"
JWT_SECRET="your-jwt-secret-here"
SESSION_SECRET="your-session-secret-here"

# ============================================================
# DISCORD BOT CREDENTIALS (Optional - for Discord Bot features)
# ============================================================
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""
DISCORD_GUILD_ID=""
DISCORD_ADMIN_ROLE_ID=""
DISCORD_MOD_ROLE_ID=""

# ============================================================
# DISCORD OAUTH2 (Optional - for Discord login)
# ============================================================
# Create OAuth2 credentials at https://discord.com/developers/applications
# Add redirect: https://your-domain.com/api/auth/discord/callback
NEXT_PUBLIC_DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:3000/api/auth/discord/callback"

# ============================================================
# PANEL ADMIN CREDENTIALS (Admin account - seeded on first run)
# ============================================================
# Set these to create the initial admin account
ADMIN_USERNAME="your-admin-username"
ADMIN_PASSWORD="your-strong-admin-password"
ADMIN_EMAIL="your-admin-email@example.com"

# ============================================================
# APPLICATION
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"